TUNNEL_TOKEN=<YOUR_TUNNEL_TOKEN_HERE>

# Used by backend-go/backend-rust/backend-ts to send an SMS via Twilio when
# the contact form is submitted. TWILIO_TO_NUMBER is the personal number that
# receives the notification.
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID_HERE>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN_HERE>
TWILIO_FROM_NUMBER=<YOUR_TWILIO_FROM_NUMBER_HERE>
TWILIO_TO_NUMBER=<YOUR_PERSONAL_PHONE_NUMBER_HERE>
