{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@iota/types": ["./src/iota-types.d.ts"],
      "@iota/ui": ["../../shared/ui/src/index.ts"]
    }
  },
  "include": ["src"]
}
