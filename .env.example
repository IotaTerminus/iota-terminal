# Local dev only — copy to .env at the repo root (never commit .env).
# Each backend (go/rust/ts) loads this file directly when run via its
# documented local dev command (e.g. `cd apps/backend-go && go run main.go`).
# In production, deploy/docker-compose.yml injects these same variables into
# each container instead (see deploy/.env.example) — this root .env is not
# used there.
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID_HERE>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN_HERE>
TWILIO_FROM_NUMBER=<YOUR_TWILIO_FROM_NUMBER_HERE>
TWILIO_TO_NUMBER=<YOUR_PERSONAL_PHONE_NUMBER_HERE>
