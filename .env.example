# Copy to .env (gitignored) and fill in real values, or let the Pi's
# 1Password environment inject .env directly — either way this file is only
# consumed locally, never committed.

# Cloudflare Tunnel ID from `cloudflared tunnel create iota-terminal`.
# Used by deploy/cloudflared/generate-config.sh to render
# deploy/cloudflared/config.yml from config.yml.example.
TUNNEL_ID=<TUNNEL_ID>
